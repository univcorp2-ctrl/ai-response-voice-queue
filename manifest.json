{
  "manifest_version": 3,
  "name": "AI Response Voice Queue",
  "version": "1.0.0",
  "description": "ChatGPT、Claude、Codex等の新しい回答を検出し、競合を避けて順番に読み上げます。",
  "permissions": ["storage", "tts", "tabs"],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://claude.ai/*",
    "https://*.openai.com/*"
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "action": {
    "default_title": "AI Response Voice Queue",
    "default_popup": "src/popup.html"
  },
  "options_page": "src/options.html",
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*",
        "https://*.openai.com/*"
      ],
      "js": ["src/content.js"],
      "run_at": "document_idle"
    }
  ]
}
